    local targets = {}
    
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local passTeam = true
            if _G.TeamCheck and p.Team == LocalPlayer.Team then
                passTeam = false
            end
            if passTeam then
                table.insert(targets, p.Character)
            end
        end
    end
    
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("Model") and obj ~= LocalPlayer.Character then
            if obj:FindFirstChild("Humanoid") and obj:FindFirstChild(_G.TargetPart) then
                if not Players:GetPlayerFromCharacter(obj) then
                    table.insert(targets, obj)
                end
            end
        end
    end
    
    return targets
end

-- Find closest target based on 3D distance (The original method you liked)
local function getClosestTarget()
    local targets = getTargets()
    local closestModel = nil
    local shortestDistance = math.huge
    
    local myChar = LocalPlayer.Character
    if not myChar or not myChar:FindFirstChild("HumanoidRootPart") then return nil end
    local myPos = myChar.HumanoidRootPart.Position
    
    for _, char in ipairs(targets) do
        local targetPart = char:FindFirstChild(_G.TargetPart)
        local hum = char:FindFirstChildOfClass("Humanoid")
        
        if targetPart and hum and hum.Health > 0 then
            local dist = (targetPart.Position - myPos).Magnitude
            if dist < shortestDistance then
                shortestDistance = dist
                closestModel = char
            end
        end
    end
    return closestModel
end

--// ORIGINAL SNAP LOCK LOOP
RunService:BindToRenderStep("MobileAimbotLock", Enum.RenderPriority.Camera.Value + 1, function()
    local myChar = LocalPlayer.Character
    if not myChar then return end
    
    local humanoid = myChar:FindFirstChildOfClass("Humanoid")
    local myRoot = myChar:FindFirstChild("HumanoidRootPart")
    
    if _G.AimbotEnabled then
        local target = getClosestTarget()
        if target and myRoot and humanoid then
            local targetPart = target:FindFirstChild(_G.TargetPart)
            if targetPart then
                -- Disable mobile joystick auto-rotation so it doesn't break camera lock
                humanoid.AutoRotate = false
                
                -- Snap camera directly to target head coordinate
                Camera.CFrame = CFrame.new(Camera.CFrame.Position, targetPart.Position)
                
                -- Snap character root to face the target coordinate
                local flatTargetPos = Vector3.new(targetPart.Position.X, myRoot.Position.Y, targetPart.Position.Z)
                myRoot.CFrame = CFrame.new(myRoot.Position, flatTargetPos)
                return
            end
        end
    end
    
    -- Restore normal joystick control if Aimbot is turned off or target is lost
    if humanoid and not humanoid.AutoRotate then
        humanoid.AutoRotate = true
    end
end)
   end,
