local Toggle = MainTab:CreateToggle({
   Name = "Esp",
   CurrentValue = false,
   Flag = "Toggle1", -- A flag is the identifier for the configuration file; make sure every element has a different flag if you're using configuration saving to ensure no overlaps
   Callback = function(Value)
  -- Standalone ESP Script (LocalScript inside StarterPlayerScripts or StarterCharacterScripts)
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Workspace = game:GetService("Workspace")

local LocalPlayer = Players.LocalPlayer
local Camera = Workspace.CurrentCamera

--// GLOBAL TOGGLE (Change this to true/false from any script to turn ESP on/off!)
_G.EspEnabled = true 
_G.TeamCheck = false -- Set to true if you don't want to highlight teammates

local activeHighlights = {}

--// GET VALID TARGETS (Both players and training dummies)
local function getTargets()
    local targets = {}
    
    -- Get other players
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local passTeam = true
            if _G.TeamCheck and p.Team == LocalPlayer.Team then
                passTeam = false
            end
            if passTeam then
                table.insert(targets, p.Character)
            end
        end
    end
    
    -- Get workspace dummies/NPCs
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("Model") and obj ~= LocalPlayer.Character then
            if obj:FindFirstChild("Humanoid") and obj:FindFirstChild("Head") then
                if not Players:GetPlayerFromCharacter(obj) then
                    table.insert(targets, obj)
                end
            end
        end
    end
    
    return targets
end

--// ESP RENDER LOOP
RunService.RenderStepped:Connect(function()
    -- If ESP is turned off, destroy all active highlights and exit
    if not _G.EspEnabled then
        for model, hl in pairs(activeHighlights) do
            if hl then hl:Destroy() end
        end
        table.clear(activeHighlights)
        return
    end

    local currentTargets = getTargets()
    local activeTargetMap = {}

    -- Apply or update highlights
    for _, char in ipairs(currentTargets) do
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum and hum.Health > 0 then
            activeTargetMap[char] = true
            
            local hl = activeHighlights[char]
            if not hl or not hl.Parent then
                hl = Instance.new("Highlight")
                hl.Name = "EspRender"
                hl.FillColor = Color3.fromRGB(255, 0, 0)        -- Red fill color
                hl.FillTransparency = 0.4                       -- Semi-transparent fill
                hl.OutlineColor = Color3.fromRGB(255, 255, 255)  -- White outline
                hl.OutlineTransparency = 0                      -- Solid outline
                hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop -- See through walls
                hl.Adornee = char
                hl.Parent = Camera
                
                activeHighlights[char] = hl
            end
        end
    end

    -- Clean up highlights for players/dummies who died, left, or are no longer targets
    for model, hl in pairs(activeHighlights) do
        if not activeTargetMap[model] or not model:Parent() then
            if hl then hl:Destroy() end
            activeHighlights[model] = nil
        end
    end
end) 
   end,
})

local Toggle = MainTab:CreateToggle({
   Name = "Aimbot",
   CurrentValue = false,
   Flag = "Toggle1", -- A flag is the identifier for the configuration file; make sure every element has a different flag if you're using configuration saving to ensure no overlaps
   Callback = function(Value)
   -- Standalone Aimbot Script (LocalScript inside StarterPlayerScripts or StarterCharacterScripts)
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Workspace = game:GetService("Workspace")

local LocalPlayer = Players.LocalPlayer
local Camera = Workspace.CurrentCamera

--// GLOBAL CONFIGURATION (Toggle these from your button script!)
_G.AimbotEnabled = false 
_G.TeamCheck = false
_G.TargetPart = "Head"
_G.FovRadius = 300 -- How close they need to be to the center of your screen to lock on

--// GET VALID TARGETS
local function getTargets()
    local targets = {}
    
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local passTeam = true
            if _G.TeamCheck and p.Team == LocalPlayer.Team then
                passTeam = false
            end
            if passTeam then
                table.insert(targets, p.Character)
            end
        end
    end
    
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("Model") and obj ~= LocalPlayer.Character then
            if obj:FindFirstChild("Humanoid") and obj:FindFirstChild(_G.TargetPart) then
                if not Players:GetPlayerFromCharacter(obj) then
                    table.insert(targets, obj)
                end
            end
        end
    end
    
    return targets
end

--// FIND TARGET CLOSEST TO THE CENTER OF YOUR SCREEN
local function getClosestTargetToScreenCenter()
    local targets = getTargets()
    local closestModel = nil
    local shortestScreenDistance = _G.FovRadius
    
    local screenCenter = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    
    for _, char in ipairs(targets) do
        local targetPart = char:FindFirstChild(_G.TargetPart)
        local hum = char:FindFirstChildOfClass("Humanoid")
        
        if targetPart and hum and hum.Health > 0 then
            local screenPos, onScreen = Camera:WorldToViewportPoint(targetPart.Position)
            
            if onScreen then
                local screenPos2D = Vector2.new(screenPos.X, screenPos.Y)
                local distToCenter = (screenPos2D - screenCenter).Magnitude
                
                if distToCenter < shortestScreenDistance then
                    shortestScreenDistance = distToCenter
                    closestModel = char
                end
            end
        end
    end
    return closestModel
end

--// BACKEND LOCK-ON LOOP
RunService:BindToRenderStep("MobileAimbotLockBackend", Enum.RenderPriority.Camera.Value + 1, function()
    local myChar = LocalPlayer.Character
    if not myChar then return end
    
    local humanoid = myChar:FindFirstChildOfClass("Humanoid")
    local myRoot = myChar:FindFirstChild("HumanoidRootPart")
    
    if _G.AimbotEnabled and myRoot and humanoid then
        local target = getClosestTargetToScreenCenter()
        
        if target then
            local targetPart = target:FindFirstChild(_G.TargetPart)
            if targetPart then
                -- Disable auto-rotate so mobile movement joystick doesn't fight the camera
                humanoid.AutoRotate = false
                
                -- Snap camera directly to target
                Camera.CFrame = CFrame.new(Camera.CFrame.Position, targetPart.Position)
                
                -- Snap character root to face the target
                local flatTargetPos = Vector3.new(targetPart.Position.X, myRoot.Position.Y, targetPart.Position.Z)
                myRoot.CFrame = CFrame.new(myRoot.Position, flatTargetPos)
                return
            end
        end
    end
    
    -- Restore normal movement controls when aimbot is off or no target is found
    if humanoid and not humanoid.AutoRotate then
        humanoid.AutoRotate = true
    end
end)
   end,
})
